{
  "buffer": 512,
  "min_level": "info",
  "batch_size": 100,
  "flush_interval": 500,
  "levels": [
    {
      "level": "debug",
      "appenders": [
        {
          "name": "console-debug",
          "type": "console",
          "formatter": { "name": "jsonfmt", "type": "json" }
        }
      ]
    },
    {
      "level": "info",
      "appenders": [
        {
          "name": "rotating-info",
          "type": "rotating_file",
          "path": "./logs/info.log",
          "max_size": 3,
          "max_age": 14,
          "max_backups": 5,
          "local_time": true,
          "compress": false,
          "formatter": { "name": "textfmt", "type": "text" }
        }
      ]
    },
    {
      "level": "warning",
      "appenders": [
        {
          "name": "console-warn",
          "type": "console",
          "formatter": { "name": "jsonfmt", "type": "json" }
        },
        {
          "name": "rotating-warn",
          "type": "rotating_file",
          "path": "./logs/warn.log",
          "max_size": 50,
          "max_age": 14,
          "max_backups": 5,
          "local_time": true,
          "compress": false,
          "formatter": { "name": "textfmt", "type": "text" }
        }
      ]
    },
    {
      "level": "error",
      "appenders": [
        {
          "name": "console-error",
          "type": "console",
          "formatter": { "name": "jsonfmt", "type": "json" }
        },
        {
          "name": "rotating-error",
          "type": "rotating_file",
          "path": "./logs/error.log",
          "max_size": 100,
          "max_age": 30,
          "max_backups": 7,
          "local_time": true,
          "compress": true,
          "formatter": { "name": "textfmt", "type": "text" }
        }
      ]
    }
  ]
}
